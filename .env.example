# Public site URL (embedded in metadata and sitemap)
NEXT_PUBLIC_SITE_URL=https://loupkids.com

# Sanity CMS — required for editable content and /studio
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=
SANITY_REVALIDATE_SECRET=

# Analytics (optional)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
GA4_API_SECRET=
META_CAPI_ACCESS_TOKEN=

# Stripe checkout (production orders)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Legacy Shopify cart integration (product catalog fallback)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# Contact form webhook (optional)
CONTACT_WEBHOOK_URL=

# Multi-instance Next.js deployments
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
