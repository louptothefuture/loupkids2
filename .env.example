# Public values: supply these as Docker build arguments because Next.js embeds
# NEXT_PUBLIC_* values into the browser bundle during `next build`.
NEXT_PUBLIC_SITE_URL=https://loupkids.com
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Runtime secrets: store these in AWS Secrets Manager or SSM Parameter Store.
# Never pass them as Docker build arguments or commit real values.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GA4_API_SECRET=
META_CAPI_ACCESS_TOKEN=
CONTACT_WEBHOOK_URL=

# Legacy Shopify cart integration. The current PDP checkout uses Stripe.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# Set one stable shared value before running more than one Next.js instance.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
